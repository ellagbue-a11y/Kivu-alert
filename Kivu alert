<script>
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById('page-'+id).classList.add('active');
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    const nb = document.getElementById('nav-'+id);
    if (nb) nb.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
    if (id==='dashboard') animateGauge();
  }
  window.addEventListener('scroll',()=>{ document.getElementById('nav').classList.toggle('scrolled',window.scrollY>40); });
  const hero=document.getElementById('hero');
  for(let i=0;i<14;i++){const b=document.createElement('div');b.className='bubble';const s=Math.random()*18+6;b.style.cssText=`width:${s}px;height:${s}px;left:${Math.random()*100}%;bottom:${Math.random()*65}%;animation-duration:${Math.random()*8+6}s;animation-delay:${Math.random()*6}s`;hero.appendChild(b);}
  const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){document.querySelectorAll('[data-target]').forEach(el=>{const t=+el.dataset.target,s=el.dataset.suffix||'',dur=1400,st=performance.now();function tick(n){const p=Math.min((n-st)/dur,1),ea=1-Math.pow(1-p,3);el.textContent=Math.round(ea*t)+s;if(p<1)requestAnimationFrame(tick);}requestAnimationFrame(tick);});obs.disconnect();}});});obs.observe(document.querySelector('.stats-bar'));
  function addRipple(e,el){const r=el.getBoundingClientRect(),s=document.createElement('span');s.className='ripple-effect';s.style.cssText=`left:${e.clientX-r.left-50}px;top:${e.clientY-r.top-50}px;width:100px;height:100px`;el.appendChild(s);setTimeout(()=>s.remove(),700);}
  function handleSignup(e){
    e.preventDefault();
    const name=document.getElementById('inp-name').value.trim();
    const email=document.getElementById('inp-email').value.trim();
    const area=document.getElementById('inp-area').value;
    const pass=document.getElementById('inp-pass').value;
    let ok=true;
    function se(id,inp,show){document.getElementById(id).classList.toggle('visible',show);document.getElementById(inp).classList.toggle('error',show);if(show)ok=false;}
    se('err-name','inp-name',!name);se('err-email','inp-email',!email.includes('@'));se('err-area','inp-area',!area);se('err-pass','inp-pass',pass.length<8);
    if(!ok)return;
    const btn=document.getElementById('submit-btn');btn.disabled=true;btn.innerHTML='<div class="spinner"></div> Setting up your account…';
    setTimeout(()=>{document.getElementById('signup-form-wrap').style.display='none';document.getElementById('signup-success').classList.add('active');document.getElementById('success-name').textContent='Welcome aboard, '+name.split(' ')[0]+'!';document.getElementById('success-area').textContent=area;document.getElementById('dash-area-label').textContent=area;document.getElementById('nav-dashboard').style.display='';},1800);
  }
  function animateGauge(){const c=document.getElementById('gauge-circle'),l=document.getElementById('gauge-pct');setTimeout(()=>{c.setAttribute('stroke-dasharray','233 314');const dur=1500,st=performance.now();function tick(n){const t=Math.min((n-st)/dur,1);l.textContent=Math.round(t*74)+'%';if(t<1)requestAnimationFrame(tick);}requestAnimationFrame(tick);},300);}


</script>
