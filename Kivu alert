<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kivu alert — Water Level Monitoring</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #07111f; --bg2: #0d2040; --bg3: #122848; --bg4: #163456;
      --primary: #2a7de1; --accent: #38c0f5; --text: #e4f0fa;
      --muted: #7aaec8; --soft: #b8d8f0; --danger: #e05555;
      --warn: #f59e0b; --ok: #22c55e; --border: rgba(56,192,245,0.15); --radius: 16px;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; }
    ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: var(--bg2); } ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 4px; }

    /* Nav */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 16px 40px; transition: background 0.4s, backdrop-filter 0.4s; }
    nav.scrolled { background: rgba(7,17,31,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .nav-logo { display: flex; align-items: center; gap: 10px; cursor: pointer; text-decoration: none; }
    .nav-logo-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--primary), var(--accent)); display: flex; align-items: center; justify-content: center; }
    .nav-logo-icon svg { width: 18px; height: 18px; fill: none; stroke: #fff; stroke-width: 2; }
    .nav-logo span { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 18px; color: var(--text); }
    .nav-links { display: flex; gap: 4px; }
    .nav-btn { padding: 8px 16px; border-radius: 10px; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; color: var(--muted); background: transparent; transition: all 0.2s; }
    .nav-btn:hover { color: var(--accent); }
    .nav-btn.active { color: var(--accent); background: rgba(56,192,245,0.1); }

    /* Pages */
    .page { display: none; } .page.active { display: block; }

    /* Hero */
    #hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 24px 80px; background: linear-gradient(180deg, #07111f 0%, #0d2040 60%, #163456 100%); overflow: hidden; }
    .wave-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
    .wave-svg { position: absolute; bottom: 0; left: 0; width: 100%; height: 40%; opacity: 0.18; }
    .wave1 { animation: waveMove1 8s ease-in-out infinite; }
    .wave2 { animation: waveMove2 11s ease-in-out infinite; }
    .wave3 { animation: waveMove3 14s ease-in-out infinite; }
    @keyframes waveMove1 { 0%,100% { d: path("M0,160 C320,260 640,60 960,160 C1280,260 1440,180 1440,180 L1440,320 L0,320 Z"); } 50% { d: path("M0,200 C320,100 640,280 960,200 C1280,100 1440,220 1440,220 L1440,320 L0,320 Z"); } }
    @keyframes waveMove2 { 0%,100% { d: path("M0,240 C360,140 720,320 1080,240 C1260,200 1440,260 1440,260 L1440,320 L0,320 Z"); } 50% { d: path("M0,200 C360,300 720,140 1080,200 C1260,240 1440,200 1440,200 L1440,320 L0,320 Z"); } }
    @keyframes waveMove3 { 0%,100% { d: path("M0,280 C480,200 960,320 1440,280 L1440,320 L0,320 Z"); } 50% { d: path("M0,300 C480,360 960,260 1440,300 L1440,320 L0,320 Z"); } }
    .bubble { position: absolute; border-radius: 50%; background: rgba(56,192,245,0.12); border: 1px solid rgba(56,192,245,0.25); animation: bubbleFloat ease-in-out infinite; }
    @keyframes bubbleFloat { 0%,100% { transform: translateY(0) scale(1); opacity: 0.6; } 50% { transform: translateY(-30px) scale(1.08); opacity: 0.9; } }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px; border-radius: 999px; margin-bottom: 32px; background: rgba(56,192,245,0.12); border: 1px solid rgba(56,192,245,0.3); font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--accent); }
    .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--ok); animation: pulse 1.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.5; transform:scale(0.8); } }
    .hero-title { font-family: 'Outfit', sans-serif; font-weight: 800; line-height: 1.05; font-size: clamp(42px,8vw,80px); color: var(--text); margin-bottom: 24px; }
    .gradient-text { background: linear-gradient(90deg, var(--primary), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .hero-sub { font-size: 18px; color: var(--muted); max-width: 560px; line-height: 1.7; margin-bottom: 40px; }
    .btn-group { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; border-radius: 16px; border: none; cursor: pointer; background: linear-gradient(135deg, var(--primary), var(--accent)); color: #07111f; font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 16px; transition: transform 0.2s, box-shadow 0.2s; }
    .btn-primary:hover { transform: scale(1.04); box-shadow: 0 8px 32px rgba(42,125,225,0.35); }
    .btn-outline { display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; border-radius: 16px; cursor: pointer; background: transparent; border: 1px solid rgba(56,192,245,0.3); color: var(--soft); font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 16px; transition: background 0.2s; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); }
    .chevron-down { position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); color: var(--primary); animation: bounce 2s ease-in-out infinite; }
    @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-8px); } }

    /* Stats */
    .stats-bar { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .stats-inner { max-width: 1100px; margin: 0 auto; padding: 40px 24px; display: grid; grid-template-columns: repeat(4,1fr); text-align: center; gap: 24px; }
    .stat-num { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 40px; color: var(--accent); }
    .stat-label { font-size: 13px; color: var(--muted); margin-top: 4px; }

    /* Features */
    .section { max-width: 1100px; margin: 0 auto; padding: 80px 24px; }
    .section-eyebrow { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
    .section-title { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 36px; color: var(--text); margin-bottom: 48px; text-align: center; }
    .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .feature-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; transition: transform 0.25s, border-color 0.25s; position: relative; overflow: hidden; cursor: pointer; }
    .feature-card:hover { transform: translateY(-4px); border-color: rgba(56,192,245,0.3); }
    .feature-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(42,125,225,0.15); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; color: var(--accent); }
    .feature-icon svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 2; }
    .feature-title { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .feature-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }
    .ripple-effect { position: absolute; border-radius: 50%; pointer-events: none; background: rgba(56,192,245,0.2); animation: rippleOut 0.7s ease-out forwards; }
    @keyframes rippleOut { 0% { transform:scale(0); opacity:1; } 100% { transform:scale(6); opacity:0; } }

    /* CTA */
    .cta-banner { max-width: 1100px; margin: 0 auto 80px; padding: 0 24px; }
    .cta-inner { background: linear-gradient(135deg,#163456,#0d2040,#163456); border: 1px solid rgba(56,192,245,0.2); border-radius: 24px; padding: 64px 40px; text-align: center; }
    .cta-inner h2 { font-family: 'Outfit', sans-serif; font-size: 32px; font-weight: 700; color: var(--text); margin-bottom: 12px; }
    .cta-inner p { font-size: 15px; color: var(--muted); max-width: 480px; margin: 0 auto 32px; line-height: 1.7; }

    /* About */
    .about-wrap { max-width: 800px; margin: 0 auto; padding: 120px 24px 80px; }
    .about-wrap h1 { font-family: 'Outfit', sans-serif; font-size: clamp(32px,5vw,52px); font-weight: 800; color: var(--text); margin-bottom: 24px; line-height: 1.1; }
    .about-wrap p { font-size: 16px; color: var(--muted); line-height: 1.8; margin-bottom: 28px; }
    .how-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; margin-bottom: 32px; }
    .how-card h2 { font-family: 'Outfit', sans-serif; font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 20px; }
    .how-step { display: flex; gap: 16px; margin-bottom: 20px; align-items: flex-start; }
    .how-step svg { width: 20px; height: 20px; color: var(--accent); fill: none; stroke: currentColor; stroke-width: 2; flex-shrink: 0; margin-top: 2px; }
    .how-step-title { font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 15px; color: var(--text); margin-bottom: 4px; }
    .how-step-desc { font-size: 14px; color: var(--muted); line-height: 1.6; }

    /* Signup */
    .signup-wrap { min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 120px 24px 80px; }
    .signup-card { width: 100%; max-width: 440px; }
    .signup-card h1 { font-family: 'Outfit', sans-serif; font-size: 40px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
    .signup-card .sub { font-size: 14px; color: var(--muted); margin-bottom: 36px; }
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600; color: var(--soft); margin-bottom: 8px; }
    .form-input, .form-select { width: 100%; padding: 14px 16px; border-radius: 14px; background: var(--bg3); border: 1px solid rgba(56,192,245,0.2); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; transition: border-color 0.2s; appearance: none; }
    .form-input::placeholder { color: var(--muted); }
    .form-input:focus, .form-select:focus { border-color: var(--accent); }
    .form-input.error, .form-select.error { border-color: var(--danger); }
    .form-select option { background: var(--bg2); }
    .field-error { font-size: 12px; color: var(--danger); margin-top: 6px; display: none; }
    .field-error.visible { display: block; }
    .btn-submit { width: 100%; padding: 16px; border-radius: 16px; border: none; cursor: pointer; background: linear-gradient(135deg,var(--primary),var(--accent)); color: #07111f; font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 16px; transition: transform 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px; }
    .btn-submit:hover { transform: scale(1.02); }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .signin-link { text-align: center; font-size: 13px; color: var(--muted); margin-top: 20px; }
    .signin-link a { color: var(--accent); cursor: pointer; }
    .spinner { width: 16px; height: 16px; border: 2px solid rgba(7,17,31,0.3); border-top-color: #07111f; border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .success-screen { min-height: 100vh; display: none; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px; }
    .success-screen.active { display: flex; }
    .success-icon { width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 24px; background: rgba(56,192,245,0.12); border: 2px solid var(--accent); display: flex; align-items: center; justify-content: center; }
    .success-icon svg { width: 36px; height: 36px; color: var(--accent); fill: none; stroke: currentColor; stroke-width: 2; }
    .success-screen h2 { font-family: 'Outfit', sans-serif; font-size: 36px; font-weight: 700; color: var(--text); margin-bottom: 12px; }
    .success-screen p { font-size: 16px; color: var(--muted); max-width: 400px; margin: 0 auto 32px; line-height: 1.7; }
    .success-area { color: var(--accent); }

    /* Dashboard */
    .dashboard-wrap { max-width: 1100px; margin: 0 auto; padding: 100px 24px 80px; }
    .dash-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 36px; flex-wrap: wrap; gap: 16px; }
    .dash-location { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    .dash-location svg { width: 14px; height: 14px; fill: none; stroke: var(--accent); stroke-width: 2; }
    .dash-title { font-family: 'Outfit', sans-serif; font-size: 32px; font-weight: 700; color: var(--text); }
    .live-badge { display: flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 999px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); font-family: 'DM Mono', monospace; font-size: 11px; color: var(--ok); }
    .metrics-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 24px; }
    .metric-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; cursor: pointer; position: relative; overflow: hidden; transition: border-color 0.2s; }
    .metric-card:hover { border-color: rgba(56,192,245,0.3); }
    .metric-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .metric-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
    .metric-icon { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; }
    .metric-value { font-family: 'Outfit', sans-serif; font-size: 30px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .metric-sub { font-size: 12px; }
    .charts-row { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px; }
    .chart-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; }
    .chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .chart-title { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600; color: var(--text); }
    .badge-rising { font-family: 'DM Mono', monospace; font-size: 11px; padding: 4px 12px; border-radius: 999px; background: rgba(224,85,85,0.12); color: var(--danger); }
    .chart-svg { width: 100%; overflow: visible; }
    .gauge-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: calc(100% - 60px); }
    .gauge-svg { width: 148px; height: 148px; }
    .gauge-center { text-align: center; margin-top: -8px; }
    .gauge-pct { font-family: 'Outfit', sans-serif; font-size: 28px; font-weight: 700; }
    .gauge-sub { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }
    .risk-badge { margin-top: 16px; padding: 8px 24px; border-radius: 999px; font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; }
    .risk-note { margin-top: 12px; font-size: 12px; color: var(--muted); text-align: center; max-width: 180px; line-height: 1.5; }
    .bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .alert-list { display: flex; flex-direction: column; gap: 12px; }
    .alert-item { display: flex; gap: 12px; padding: 14px 16px; border-radius: 12px; background: var(--bg3); }
    .alert-icon { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; flex-shrink: 0; margin-top: 2px; }
    .alert-msg { font-size: 13px; color: var(--text); line-height: 1.5; margin-bottom: 4px; }
    .alert-time { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }
    .trend-badge { font-family: 'DM Mono', monospace; font-size: 11px; display: flex; align-items: center; gap: 6px; }
    .trend-badge svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2; }

    @media (max-width: 900px) {
      nav { padding: 16px 20px; }
      .stats-inner { grid-template-columns: repeat(2,1fr); }
      .features-grid { grid-template-columns: 1fr 1fr; }
      .metrics-grid { grid-template-columns: repeat(2,1fr); }
      .charts-row, .bottom-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .nav-links { display: none; }
      .features-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<nav id="nav">
  <a class="nav-logo" onclick="showPage('home')">
    <div class="nav-logo-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z"/></svg>
    </div>
    <span>Kivu alert</span>
  </a>
  <div class="nav-links">
    <button class="nav-btn active" id="nav-home" onclick="showPage('home')">Home</button>
    <button class="nav-btn" id="nav-about" onclick="showPage('about')">About</button>
    <button class="nav-btn" id="nav-signup" onclick="showPage('signup')">Sign Up</button>
    <button class="nav-btn" id="nav-dashboard" onclick="showPage('dashboard')" style="display:none">Dashboard</button>
  </div>
</nav>

<!-- HOME -->
<div id="page-home" class="page active">
  <section id="hero">
    <div class="wave-bg">
      <svg class="wave-svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path class="wave1" fill="#2a7de1" d="M0,160 C320,260 640,60 960,160 C1280,260 1440,180 1440,180 L1440,320 L0,320 Z"/>
        <path class="wave2" fill="#163456" d="M0,240 C360,140 720,320 1080,240 C1260,200 1440,260 1440,260 L1440,320 L0,320 Z"/>
        <path class="wave3" fill="#38c0f5" d="M0,280 C480,200 960,320 1440,280 L1440,320 L0,320 Z"/>
      </svg>
    </div>
    <div class="hero-badge"><div class="pulse"></div>LIVE MONITORING — MARA BASIN REGION</div>
    <h1 class="hero-title">Know before the<br><span class="gradient-text">water rises.</span></h1>
    <p class="hero-sub">Kivu alert delivers real-time water level data, rise tendency forecasts, and geo-targeted flood alerts — so you and your community are never caught off guard.</p>
    <div class="btn-group">
      <button class="btn-primary" onclick="showPage('signup')">Get Free Access <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
      <button class="btn-outline" onclick="showPage('about')">Learn More</button>
    </div>
    <div class="chevron-down"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></div>
  </section>
  <div class="stats-bar">
    <div class="stats-inner">
      <div><div class="stat-num" data-target="24" data-suffix="/7">0/7</div><div class="stat-label">Live Coverage</div></div>
      <div><div class="stat-num" data-target="98" data-suffix="%">0%</div><div class="stat-label">Alert Accuracy</div></div>
    </div>
  </div>
  <div class="section">
    <div style="text-align:center"><div class="section-eyebrow">What You Get</div><div class="section-title">Everything you need to stay safe</div></div>
    <div class="features-grid">
      <div class="feature-card" onclick="addRipple(event,this)"><div class="feature-icon"><svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div><div class="feature-title">Real-Time Monitoring</div><div class="feature-desc">Continuous water level readings from sensor networks across your region, updated every 15 minutes.</div></div>
      <div class="feature-card" onclick="addRipple(event,this)"><div class="feature-icon"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg></div><div class="feature-title">Instant Alerts</div><div class="feature-desc">Receive SMS and email notifications when water levels exceed safe thresholds in your area.</div></div>
      <div class="feature-card" onclick="addRipple(event,this)"><div class="feature-icon"><svg viewBox="0 0 24 24"><path d="M23 6l-9.5 9.5-5-5L1 18M17 6h6v6"/></svg></div><div class="feature-title">Rise Tendency Analysis</div><div class="feature-desc">ML models predict water rise patterns 6–48 hours in advance with measurable accuracy.</div></div>
